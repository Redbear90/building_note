# 백엔드 환경변수 — 실제 값은 .env(또는 시스템 환경변수)에서 주입.
# 이 파일은 커밋해도 안전하지만 .env는 절대 커밋 금지.

# ── 데이터베이스 ─────────────────────────────────────────
# 로컬: PostgreSQL 16. AWS 운영: RDS endpoint.
DB_URL=jdbc:postgresql://localhost:5432/building_note
DB_USERNAME=buildnote
DB_PASSWORD=change-me

# ── JWT ─────────────────────────────────────────────────
# 최소 32바이트(256bit). 운영에서는 base64 인코딩된 무작위 키 권장.
#   $ openssl rand -base64 48
JWT_SECRET=change-me-with-32-or-more-bytes-for-hs256-signing-key

# ── 프로파일 ────────────────────────────────────────────
# local | prod
SPRING_PROFILE=local

# ── CORS ────────────────────────────────────────────────
# 콤마 구분 다중 오리진. 와일드카드 패턴 지원.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4173
